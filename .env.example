# ─── LLM 配置（必填）─────────────────────────
# DeepSeek / OpenAI-compatible Chat Completions API
#
# 后端 dev 脚本会从项目根目录 .env 读取这些变量。
# 使用时请复制本文件为项目根目录 .env，不要把真实 API Key 提交到仓库。

# API 密钥（必填）
# DeepSeek: https://platform.deepseek.com/api_keys
LLM_API_KEY=sk-your-api-key-here

# API Base URL（必填，需包含 /v1，不要以 / 结尾也可以，代码会做兼容）
# DeepSeek: https://api.deepseek.com/v1
LLM_BASE_URL=https://api.deepseek.com/v1

# 模型名（必填）
# DeepSeek 常用模型：deepseek-v4-flash、deepseek-v4-pro
LLM_MODEL=deepseek-v4-flash

# ─── 数据库配置（阶段 2 必填）──────────────────
# PostgreSQL 连接字符串。
# 本地示例：postgresql://postgres:postgres@localhost:5432/agent_ai_seo?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_ai_seo?schema=public
